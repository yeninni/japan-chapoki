# ══════════════════════════════════════════════════════════════════════
# Tilon AI Chatbot — Environment Configuration
# Copy this file to .env and modify as needed
# ══════════════════════════════════════════════════════════════════════

# ── Ollama / LLM ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=qwen2.5:7b
VISION_MODEL=qwen2.5vl:7b
AVAILABLE_MODELS=qwen2.5:7b,qwen2.5vl:7b,llama3.1:latest,mistral:7b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=180
LLM_REPEAT_PENALTY=1.15
LLM_REPEAT_LAST_N=128

# ── Embedding ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cuda    # set explicitly on GPU machines; auto-detected if omitted

# ── Reranker (optional — improves retrieval accuracy) ─────────────────
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=3
RERANKER_DEVICE=cpu
RERANKER_USE_FP16=true

# ── Retrieval ─────────────────────────────────────────────────────────
VECTOR_TOP_K=4
GLOBAL_MIN_RELEVANCE_SCORE=0.30
DOCUMENT_CONFIDENCE_THRESHOLD=0.45
SCOPED_SINGLE_CHUNK_CONFIDENCE_THRESHOLD=0.30
STRONG_KEYWORD_CONFIDENCE_FLOOR=0.75

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ── Paths ─────────────────────────────────────────────────────────────
# DATA_DIR=./data
# LIBRARY_DIR=./data/library
# UPLOADS_DIR=./data/uploads
# TEMP_DIR=./data/temp
# CHROMA_DIR=./chroma_db

# ── Features ──────────────────────────────────────────────────────────
ENABLE_OCR=true
OCR_ENGINE=auto
PADDLEOCR_DEFAULT_LANG=korean
AUTO_INGEST_ON_STARTUP=false
WHISPER_MODEL=base
WHISPER_LANGUAGE=ko

# ── VLM PDF Extraction ────────────────────────────────────────────────
VLM_EXTRACTION_ENABLED=true
VLM_EXTRACTION_MODEL=qwen2.5vl:7b

# ── Web Search ────────────────────────────────────────────────────────
TAVILY_API_KEY=
DUCKDUCKGO_MAX_RESULTS=5
DUCKDUCKGO_REGION=kr-kr

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Large file ingest speed mode (for very big PDFs)
LARGE_FILE_FAST_MODE=true
LARGE_FILE_PAGE_THRESHOLD=80
LARGE_FILE_MAX_FALLBACK_PAGES=12
LARGE_FILE_CHUNK_SIZE=2200
LARGE_FILE_CHUNK_OVERLAP=100
